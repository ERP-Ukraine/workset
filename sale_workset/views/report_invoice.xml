<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_invoice_document" inherit_id="account.report_invoice_document">
    <xpath expr="//div[@id='informations']" position="attributes">
        <attribute name="class" remove="mb-4" separator=" "/>
    </xpath>

    <xpath expr="//div[@id='informations']" position="inside">
        <div t-if="o.execution_start_date" class="col-auto col-3 mw-100 mb-2" name="execution_start_date">
            <strong>Execution Start Date:</strong>
            <p class="m-0" t-field="o.execution_start_date" t-options="{'widget': 'date'}"/>
        </div>
        <div t-if="o.execution_end_date" class="col-auto col-3 mw-100 mb-2" name="execution_start_date">
            <strong>Execution End Date:</strong>
            <p class="m-0" t-field="o.execution_end_date" t-options="{'widget': 'date'}"/>
        </div>
    </xpath>

    <xpath expr="//div[@id='informations']" position="after">
        <div class="row mb-4" id="object_details">
            <div t-if="o.object_id" class="col-auto col-12 mw-100 mb-2" name="object_id">
                <strong>Object:</strong>
                <t t-set="object_address" t-value="[o.object_id.name, o.object_id.zip,  o.object_id.state_id.name, o.object_id.city, o.object_id.street, o.object_id.country_id.name,]"/>
                <p class="m-0" t-esc="', '.join(value for value in object_address if value)"/>
            </div>
        </div>
    </xpath>

    <!-- hide quantity and price fields (th) -->
    <xpath expr="//th[@name='th_quantity']" position="attributes">
        <attribute name="t-if">not o.hide_qty_price</attribute>
    </xpath>

    <xpath expr="//th[@name='th_priceunit']" position="attributes">
        <attribute name="t-if">not o.hide_qty_price</attribute>
    </xpath>

    <xpath expr="//th[@name='th_price_unit']" position="attributes">
        <attribute name="t-if">not o.hide_qty_price</attribute>
    </xpath>

    <!-- hide quantity and price fields (td) -->
    <xpath expr="//span[@t-field='line.product_uom_id']/parent::td" position="attributes">
        <attribute name="t-if">not o.hide_qty_price</attribute>
    </xpath>

    <xpath expr="//span[@t-field='line.price_unit']/parent::td" position="attributes">
        <attribute name="t-if">not o.hide_qty_price</attribute>
    </xpath>

    <xpath expr="//td[@t-if='display_discount']" position="attributes">
        <attribute name="t-if">display_discount and not o.hide_qty_price</attribute>
    </xpath>
</template>

</odoo>
