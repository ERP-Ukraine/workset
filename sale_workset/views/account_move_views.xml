<?xml version="1.0" encoding="utf-8"?>
<odoo>

<record id="view_move_form" model="ir.ui.view">
    <field name="name">account.move.form.workset</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
        <xpath expr="//notebook" position="inside">
            <page string="Workset" name="workset">
                <group>
                    <group>
                        <field name="object_id"/>
                        <field name="hide_qty_price"/>
                    </group>
                    <group>
                        <label for="execution_start_date" string="Execution Period"/>
                        <div class="d-flex">
                            <field name="execution_start_date" placeholder="Start Date"/>
                            <span class="o_form_label mx-3 oe_edit_only"> – </span>
                            <field name="execution_end_date" placeholder="End Date"/>
                        </div>
                        <!-- <field name="execution_start_date"/> -->
                        <!-- <field name="execution_end_date"/> -->
                    </group>
                </group>
            </page>
        </xpath>
    </field>
</record>

</odoo>
