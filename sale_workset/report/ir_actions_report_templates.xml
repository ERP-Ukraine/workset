<?xml version="1.0" encoding="utf-8"?>
<odoo>

<template id="report_saleorder_document" inherit_id="sale.report_saleorder_document">
    <xpath expr="//div[@id='informations']" position="attributes">
        <attribute name="class" remove="mb-4" separator=" "/>
    </xpath>

    <xpath expr="//div[@id='informations']" position="inside">
        <div t-if="doc.execution_start_date or doc.execution_end_date" class="col-auto col-3 mw-100 mb-2" name="execution_dates">
            <strong>Execution Period:</strong>
            <p class="m-0">
                <span t-field="doc.execution_start_date" t-options="{'widget': 'date'}"/>
                -
                <span t-field="doc.execution_end_date" t-options="{'widget': 'date'}"/>
            </p>
        </div>
    </xpath>

    <xpath expr="//div[@id='informations']" position="after">
        <div class="row mb-4" id="object_details">
            <div t-if="doc.object_id" class="col-auto col-12 mw-100 mb-2" name="object_id">
                <strong>Object:</strong>
                <t t-set="object_address" t-value="[doc.object_id.name, doc.object_id.zip,  doc.object_id.state_id.name, doc.object_id.city, doc.object_id.street, doc.object_id.country_id.name,]"/>
                <p class="m-0" t-esc="', '.join(value for value in object_address if value)"/>
            </div>
        </div>
    </xpath>
</template>

</odoo>
